DATABASE_URL=postgres://paperclip:paperclip@localhost:5432/paperclip
PORT=3100
SERVE_UI=false
BETTER_AUTH_SECRET=paperclip-dev-secret

# Resend email OTP auth is enabled only when RESEND_API_KEY is set.
# For shared/public deployments, verify your own domain in Resend first and
# use an address on that domain, for example auth@your-domain.com.
# Do not use onboarding@resend.dev outside local testing; Resend only allows
# that testing sender to email the Resend account owner.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Paperclip
RESEND_REPLY_TO=
# RESEND_ALLOW_TESTING_DOMAIN=true
# Set to false to require instance-admin assignment/invites instead of
# automatically creating a personal company for newly signed-in users.
# PAPERCLIP_AUTO_CREATE_COMPANY_ON_SIGNUP=false

# MyOPC AI gateway defaults to MiniMax M3 through the Anthropic-compatible API.
# Keep the real key in server/private env, not in git.
MINIMAX_API_KEY=
PAPERCLIP_AI_GATEWAY_API_KEY=

# Discord webhook for daily merge digest (scripts/discord-daily-digest.sh)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
